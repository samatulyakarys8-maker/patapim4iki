# Keep this only on the local backend. Never paste it into extension code.
ELEVENLABS_API_KEY=replace_with_your_realtime_speech_to_text_key
ELEVENLABS_STT_MODEL=scribe_v2_realtime

# Preferred realtime voice navigator provider.
# Keep this only on the local backend. The extension requests a local runtime config.
DEEPGRAM_API_KEY=replace_with_your_deepgram_key
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=multi
DEEPGRAM_ENDPOINTING=300
DEEPGRAM_UTTERANCE_END_MS=1000

# Optional LLM parser for transcript -> structured draft patches.
# Keep this only on the local backend.
OPENROUTER_API_KEY=replace_with_your_openrouter_key
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_APP_TITLE=Damumed Sandbox Agent
OPENROUTER_APP_REFERER=http://localhost:3030
